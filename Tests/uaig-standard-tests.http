POST {{apimEndpoint}}/openai/v1/responses
api-key: {{apimSubKey}}
Content-Type: application/json

{
    "model": "gpt-4.1-mini",
    "previous_response_id": "{{v1ResponseId}}",
    "input": "Can you explain that in simpler terms that a high school student would understand?"
}

