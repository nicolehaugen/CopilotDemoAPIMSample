# APIM Gateway URL — exposed to browser (VITE_ prefix)
VITE_APIM_GATEWAY_URL=https://your-apim-name.azure-api.net/unified-ai

# APIM Subscription Key — server-side only
APIM_SUBSCRIPTION_KEY=your-subscription-key

# APIM Resource ID for management API — server-side only
APIM_RESOURCE_ID=/subscriptions/your-sub-id/resourceGroups/your-rg/providers/Microsoft.ApiManagement/service/your-apim-name

# Azure AD / Entra ID credentials — server-side only
TENANT_ID=your-tenant-id
ENTRA_APP_ID=your-client-id
ENTRA_APP_CLIENT_SECRET=your-client-secret
