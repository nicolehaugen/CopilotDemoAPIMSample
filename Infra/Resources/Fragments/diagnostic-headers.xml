<!-- 
====================================================================================================
Diagnostic Headers Fragment
====================================================================================================

SUMMARY:
	Provides diagnostic information through HTTP response headers (UAIG-*) for troubleshooting and 
	monitoring the AI Gateway pipeline. Exposes internal variable states, cache operations, routing 
	decisions, and backend selections to facilitate development and operations visibility.
	
INPUT VARIABLES:
	- api-type: Detected API type
	- auth-type: Authentication method used (api-key, jwt, none)
	- cache-operation: Cache operation performed (bypass, loaded, store)
	- cache-config-version: Configuration version for cache invalidation
	- config-api-types: API types section extracted as JObject
	- config-models: Models section extracted as JObject
	- context.Api.Path: APIM API path for prefix stripping (dynamic from APIM)
	- finalPath: Forwarded/final path for backend routing
	- is-streaming: Whether request has stream:true ("true"/"false")
	- jwt-audience: JWT audience (app ID)
	- jwt-issuer: JWT token issuer
	- jwt-openid-config: JWT OpenID configuration URL
	- model-id: Extracted model identifier
	- model-tier: Model tier (standard, premium)

	- request-timeout: Calculated request timeout in seconds
	- routing-processed-path: Path with product prefix removed
	- selected-api-version: Selected API version for the request
	- selected-backend: Selected backend pool name
	- token-limit-key: Generated token limiting key
	- user-id: User identifier from auth

OUTPUT VARIABLES:
	- UAIG-* HTTP response headers: Diagnostic headers exposing internal state
	
DOWNSTREAM CONSUMERS:
	- HTTP response to client: Diagnostic headers for troubleshooting
	
UPSTREAM DEPENDENCIES:
	- All other fragments: Runs last to capture their variable states
====================================================================================================
-->
<fragment fragment-id="diagnostic-headers">
	<!-- Cache behavior -->
	<set-header name="UAIG-Cache-Config-Models" exists-action="override">
		<value>@(context.Variables.ContainsKey("config-models") ? "set" : "missing")</value>
	</set-header>
	<set-header name="UAIG-Cache-Config-ApiTypes" exists-action="override">
		<value>@(context.Variables.ContainsKey("config-api-types") ? "set" : "missing")</value>
	</set-header>
	<set-header name="UAIG-Api-Path" exists-action="override">
		<value>@(context.Api.Path ?? "not-set")</value>
	</set-header>
	<set-header name="UAIG-Cache-Operation" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("cache-operation", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-Cache-Version" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("cache-config-version", "not-set"))</value>
	</set-header>
	<!-- Security handling -->
	<set-header name="UAIG-Auth-Type" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("auth-type", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-User-ID" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("user-id", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-JWT-OpenID-Config" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("jwt-openid-config", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-JWT-Audience" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("jwt-audience", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-JWT-Issuer" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("jwt-issuer", "not-set"))</value>
	</set-header>
	<!-- Request processing -->
	<set-header name="UAIG-Model-ID" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("model-id", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-API-Type" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("api-type", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-Is-Streaming" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault<bool>("is-streaming", false).ToString().ToLower())</value>
	</set-header>
	<set-header name="UAIG-Original-Path" exists-action="override">
		<value>@(context.Request.Url.Path)</value>
	</set-header>
	<set-header name="UAIG-Processed-Path" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("routing-processed-path", "not-set"))</value>
	</set-header>
	<!-- Path building -->
	<set-header name="UAIG-Forwarded-Path" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("finalPath", "not-set"))</value>
	</set-header>
	<!-- Backend selection -->
	<set-header name="UAIG-Selected-Backend" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("selected-backend", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-Request-Timeout" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault<int>("request-timeout", 0).ToString())</value>
	</set-header>
	<set-header name="UAIG-Selected-API-Version" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("selected-api-version", "not-set"))</value>
	</set-header>
	<!-- Token limiting -->
	<set-header name="UAIG-Token-Limit-Key" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("token-limit-key", "not-set"))</value>
	</set-header>
	<set-header name="UAIG-Model-Tier" exists-action="override">
		<value>@(context.Variables.GetValueOrDefault("model-tier", "not-set"))</value>
	</set-header>

</fragment>